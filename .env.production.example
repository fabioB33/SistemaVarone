# ═══════════════════════════════════════════════════════════════════════
# Sistema Varone — Env vars de PRODUCCIÓN (VPS)
# ═══════════════════════════════════════════════════════════════════════
#
# Copiar como .env en la raíz del proyecto ANTES del `docker compose up`:
#   cp .env.production.example .env
#   nano .env
#   chmod 600 .env
#
# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=varone
POSTGRES_PASSWORD=<GENERAR-CON-openssl-rand-hex-32>
POSTGRES_DB=sistema_varone

# El backend lee esta variable, se autoarma con las de arriba
DATABASE_URL=postgresql://varone:PASSWORD@db:5432/sistema_varone

# ─── IA ────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=<obtener-en-aistudio.google.com>
OPENAI_API_KEY=

# ─── WhatsApp ──────────────────────────────────────────────────────────
WA_GROUP_NAME=Piratería de Camiones
VARONE_WA_NUMBER=5491144462389

# ─── Framer publisher ──────────────────────────────────────────────────
FRAMER_PUBLISHER_URL=http://publisher:4001
FRAMER_PUBLISHER_TOKEN=<GENERAR-CON-openssl-rand-hex-32>

# ─── Admin panel auth (Next.js :3001) ──────────────────────────────────
BACKEND_API_TOKEN=<GENERAR-CON-openssl-rand-hex-32>
ADMIN_USER=varone
ADMIN_PASS=<CAMBIAR-DE-DEFAULT>
ADMIN_SESSION_SECRET=<GENERAR-CON-openssl-rand-hex-32>
ADMIN_PUBLIC_URL=https://<TU-DOMINIO>

# Bcrypt hash opcional (preferido sobre plaintext)
# Generar: node -e "console.log(require('bcrypt').hashSync('mi-pass', 12))"
ADMIN_PASS_BCRYPT=

# ─── Nginx-proxy + Let's Encrypt (HTTPS gratis) ────────────────────────
ADMIN_DOMAIN=<TU-DOMINIO>       # ejemplo: varone.tudominio.com
LETSENCRYPT_EMAIL=<TU-EMAIL>    # ejemplo: contacto@tudominio.com

# ─── Observabilidad (opcional) ─────────────────────────────────────────
SENTRY_DSN=

# ─── Nominatim (geocoding) ─────────────────────────────────────────────
NOMINATIM_USER_AGENT=sistema-varone/1.0 (https://<TU-DOMINIO> contacto@tudominio.com)
GEOCODE_THROTTLE_MS=1100
GEOCODE_BATCH_SIZE=50

# ─── Rate limiting ─────────────────────────────────────────────────────
RATE_LIMIT_MUTATIONS_PER_MIN=30
RATE_LIMIT_PUBLISHER_PER_MIN=10
RATE_LIMIT_LOGIN_PER_15MIN=10
RATE_LIMIT_INYECCION_PER_MIN=60

# ─── Telegram (opcional — para alertas) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sistema ────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

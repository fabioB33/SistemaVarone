# URL del backend Sistema Varone (Express en :3000)
NEXT_PUBLIC_SISTEMA_VARONE_URL=http://127.0.0.1:3000

# Token compartido con el backend (BACKEND_API_TOKEN en sistema-varone/.env).
# Permite que el Next se autentique server-to-server sin doble login.
# Generar uno largo y único: `openssl rand -hex 32`
BACKEND_API_TOKEN=

# Credenciales del login al panel (independientes del backend).
ADMIN_USER=varone
ADMIN_PASS=cambiar-esto-en-produccion

# Secret para firmar la cookie de sesión del panel (mínimo 16 chars).
# Generar: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=cambiar-por-un-secret-largo-y-random

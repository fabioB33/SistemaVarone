{
  "name": "framer-publisher",
  "version": "2.0.0",
  "description": "Sprint pivot-framer-form: microservicio Playwright que postea reportes al formulario público de pirateriadecamiones.com.ar (reemplaza la integración Framer Server API del v1).",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "extract-options": "node --env-file=.env --import tsx src/extract-framer-options.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

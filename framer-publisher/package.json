{
  "name": "framer-publisher",
  "version": "1.0.0",
  "description": "Microservicio ESM aislado para publicar noticias del Sistema Varone en Framer CMS via Server API.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "framer-api": "^0.1.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

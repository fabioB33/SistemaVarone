# Sprint pivot-framer-form (2026-06-26) — Publisher v2 con Playwright.
# Removed: FRAMER_API_KEY + FRAMER_PROJECT_URL (Server API ya no se usa).

# Credenciales del sitio público (cuenta dedicada del bot).
FRAMER_SITE_EMAIL=
FRAMER_SITE_PASSWORD=

# Persistencia de cookies/storage entre reinicios (evita re-login).
FRAMER_STORAGE_STATE_PATH=./data/framer-session.json

# Browser config (FRAMER_HEADLESS=false para debug visual).
FRAMER_HEADLESS=true
FRAMER_NAV_TIMEOUT_MS=60000

# Puerto del microservicio Express.
PORT=4001

# Token compartido para auth header X-Publisher-Token (opcional pero recomendado).
FRAMER_PUBLISHER_TOKEN=

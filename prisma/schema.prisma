generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reporte {
  id             Int      @id @default(autoincrement())
  hash           String   @unique
  fuente         String   // 'whatsapp' | 'scraping'
  fecha          String
  ubicacion      String
  ruta           String
  tipoIncidente  String   @map("tipo_incidente")
  gravedad       String?  // 'alta' | 'media' | 'baja'
  hora           String?  // HH:MM o 'desconocida'
  vehiculo       String?  // marca y tipo del vehículo
  patente        String?  // patente del vehículo si aparece
  descripcion    String
  textoOriginal  String   @map("texto_original")
  urlNoticia     String?  @map("url_noticia")
  victimas       String?  // descripción de víctimas/heridos
  detenidos      String?  // cantidad o descripción de detenidos
  framerEnviado  Boolean  @default(false) @map("framer_enviado")
  framerIntentos Int      @default(0) @map("framer_intentos")
  portalOrigen   String?  @map("portal_origen")  // nombre del portal si fuente=scraping
  creadoEn       DateTime @default(now()) @map("creado_en")

  // Flujo de aprobación + integración Framer Server API
  estado         String   @default("pendiente") // 'pendiente' | 'aprobado' | 'descartado' | 'publicado'
  aprobadoPor    String?  @map("aprobado_por")
  aprobadoEn     DateTime? @map("aprobado_en")
  framerItemId   String?  @map("framer_item_id")    // id del item creado en la Collection Notas
  framerSlug     String?  @map("framer_slug")
  ogImageUrl     String?  @map("og_image_url")      // URL de Open Graph extraída del urlNoticia

  @@map("reportes")
  @@index([estado])
}

model ResumenDiario {
  id        Int      @id @default(autoincrement())
  fecha     String   @unique  // YYYY-MM-DD
  texto     String
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("resumenes_diarios")
}

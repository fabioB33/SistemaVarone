generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reporte {
  id             Int      @id @default(autoincrement())
  hash           String   @unique
  fuente         String   // 'whatsapp' | 'scraping'
  fecha          String
  ubicacion      String
  ruta           String
  tipoIncidente  String   @map("tipo_incidente")
  gravedad       String?  // 'alta' | 'media' | 'baja'
  hora           String?  // HH:MM o 'desconocida'
  vehiculo       String?  // marca y tipo del vehículo
  patente        String?  // patente del vehículo si aparece
  descripcion    String
  textoOriginal  String   @map("texto_original")
  urlNoticia     String?  @map("url_noticia")
  victimas       String?  // descripción de víctimas/heridos
  detenidos      String?  // cantidad o descripción de detenidos
  framerEnviado  Boolean  @default(false) @map("framer_enviado")
  framerIntentos Int      @default(0) @map("framer_intentos")
  portalOrigen   String?  @map("portal_origen")  // nombre del portal si fuente=scraping
  // Sprint scrapers-portales (2026-06-30): metadata del scraping.
  tituloOriginal String?  @map("titulo_original")  // titular tal cual en el portal
  publishedAt    DateTime? @map("published_at")    // fecha de publicación del portal (no de scraping)
  creadoEn       DateTime @default(now()) @map("creado_en")

  // Sprint pivot-framer-form (2026-06-26) — Campos del formulario público
  // pirateriadecamiones.com.ar/formulario-de-incidentes. Mapeo 1:1 a dropdowns.
  // Si la IA no logra elegir alguno, queda null y va a `camposFaltantes`.
  provincia                     String? @map("provincia")
  tipoIncidenteFramer           String? @map("tipo_incidente_framer")
  fuerzaInterviniente           String? @map("fuerza_interviniente")
  tipoVehiculo                  String? @map("tipo_vehiculo")
  cargaTransportada             String? @map("carga_transportada")
  modusOperandi                 String? @map("modus_operandi")
  huboViolencia                 String? @map("hubo_violencia")
  tipoVehiculoInvolucrado       String? @map("tipo_vehiculo_involucrado")
  cantidadVehiculosInvolucrados String? @map("cantidad_vehiculos_involucrados")
  cantidadPersonasInvolucradas  String? @map("cantidad_personas_involucradas")

  // Lista de campos donde la IA marcó ambigüedad. Si tiene >0 entries,
  // estado=pendiente_revision y aparece alerta en dashboard principal.
  camposFaltantes String[] @map("campos_faltantes") @default([])

  // Flujo de aprobación + integración Framer (vía Playwright form-fill).
  // Estados:
  //  'pendiente'           → IA logró extraer todos los campos. Espera aprobación humana.
  //  'pendiente_revision'  → IA NO pudo elegir ≥1 dropdown. Varone completa antes.
  //  'aprobado'            → Varone OK, listo para publicar.
  //  'publicado'           → ya posteado al formulario público.
  //  'descartado'          → Varone NO quiso publicar.
  //  'fallo_publicacion'   → Playwright tiró error al postear. Se reintenta.
  estado         String   @default("pendiente")
  aprobadoPor    String?  @map("aprobado_por")
  aprobadoEn     DateTime? @map("aprobado_en")
  framerItemId   String?  @map("framer_item_id")
  framerSlug     String?  @map("framer_slug")
  ogImageUrl     String?  @map("og_image_url")

  @@map("reportes")
  @@index([estado])
}

model ResumenDiario {
  id        Int      @id @default(autoincrement())
  fecha     String   @unique  // YYYY-MM-DD
  texto     String
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("resumenes_diarios")
}

// Estado persistente del bot WhatsApp.
//
// Singleton: una sola fila con id=1. Los handlers del cliente WA (ready,
// disconnected, qr) actualizan esta fila. Sirve para 2 casos:
//
// 1) Al arrancar el backend, el panel admin puede mostrar el "último estado
//    conocido" mientras el cliente WA tarda en inicializar (1-2 minutos
//    de Puppeteer). Sin esto el panel arranca diciendo "esperando QR" hasta
//    que llega el primer evento real, generando confusión.
//
// 2) Healthcheck cron compara `ultimoMensajeEn` con `Date.now()` para
//    detectar bot conectado pero zombie (sin recibir mensajes >1h).
model WaState {
  id                Int      @id @default(1)
  status            String   // 'connected' | 'qr' | 'disconnected'
  ultimoCambioEn    DateTime @default(now()) @map("ultimo_cambio_en")
  ultimoMensajeEn   DateTime? @map("ultimo_mensaje_en")
  ultimoEvento      String?  @map("ultimo_evento")  // 'ready', 'disconnected', 'qr', etc.
  detalles          Json?

  @@map("wa_state")
}

// Audit log inmutable de acciones sensibles (aprobaciones, edits, descartes,
// publicaciones, login). Append-only: nunca se actualizan ni borran filas.
//
// Usos:
//  - Trazabilidad: "¿quién aprobó esto?", "¿quién editó tal campo?"
//  - Compliance: si hay polémica con una noticia publicada, hay registro completo.
//  - Detectar uso anómalo: muchos descartes en poco tiempo, login desde IP rara, etc.
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  // Tipo de evento canónico, p.ej. "aprobar.success", "aprobar.alreadyDone",
  // "descartar.success", "editar.success", "publicar.success", "publicar.fail",
  // "login.success", "login.fail", "logout", "quick-action.aprobar.success".
  evento       String
  // Quién: usuario del panel, o "quick-action-wa", o "cron-9am", o "system".
  actor        String
  // Origen del request: "panel", "quick-action", "api-direct", "cron", "system".
  origen       String
  // Reporte tocado, si aplica.
  reporteId    Int?     @map("reporte_id")
  // IP del request si la conocemos (panel/quick-action). Null en cron/system.
  ip           String?
  user_agent   String?  @map("user_agent")
  // Detalle libre en JSON: cambios aplicados en edición, error mensaje, etc.
  // Limitado a ~4 KB en práctica.
  meta         Json?
  // Timestamp inmutable.
  ts           DateTime @default(now())

  @@map("audit_log")
  @@index([reporteId])
  @@index([actor])
  @@index([evento])
  @@index([ts])
}

// Alertas operativas del sistema (modo full-auto IA).
// Cada vez que health-ai detecta una condición anómala, se registra una alerta acá.
// El panel admin las lee y muestra un badge "N alertas sin leer".
//
// Diseñado como "fuente de verdad" de notificaciones — no dependemos del canal de
// entrega (WhatsApp / Telegram / email): mientras se persistan acá, el operador
// puede verlas desde el panel.
//
// Tipos canónicos:
//  - 'silencio'         : muchos mensajes en grupo, 0 aprobados (prompt restrictivo / IA degradada)
//  - 'spike'            : muchos aprobados en poco tiempo (incidente real o falso positivo masivo)
//  - 'pendientes-viejos': reportes colgados >1h (Framer caído / sin URL)
//  - 'distribucion'     : un tipo de incidente domina las aprobaciones (sesgo del prompt)
//  - 'test'             : alertas de prueba disparadas desde el endpoint de testing
model Alerta {
  id          Int      @id @default(autoincrement())
  // Tipo canónico (uno de los listados arriba). Permite filtrar y contar por tipo.
  tipo        String
  // Mensaje formateado tal cual se envía al canal de notificación.
  // Se preserva sin truncar para que el panel muestre el texto completo.
  mensaje     String
  // Severidad para que el panel pinte distinto. 'info' / 'warn' / 'error'.
  severidad   String   @default("warn")
  // Datos estructurados de las métricas que dispararon la alerta (JSON).
  // Ej: { "mensajes": 25, "aprobados": 0, "ventanaHoras": 6 }
  meta        Json?
  // ¿Se intentó enviar por WhatsApp? Y si sí, ¿llegó OK?
  // 'pending' (default), 'sent', 'failed', 'fallback-console'
  estadoEnvio String   @default("pending") @map("estado_envio")
  // Cuándo Varone marcó la alerta como vista desde el panel. Null = sin leer.
  vistaEn     DateTime? @map("vista_en")
  // Cuándo Varone tomó alguna acción manual sobre el problema (opcional).
  // Hoy no usado por la UI, reservado para iteraciones futuras.
  resueltaEn  DateTime? @map("resuelta_en")
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@map("alertas")
  @@index([vistaEn])      // queries de "alertas no leídas" (vistaEn IS NULL)
  @@index([tipo])         // filtros por tipo
  @@index([creadoEn])     // ordenamiento descendente por fecha
}

// Sprint mapa (2026-06-27): cache de geocoding ubicación → coordenadas.
//
// Sin esto, cada renderizado del mapa pegaría 100+ requests a Nominatim,
// rompiendo el TOS (1 req/seg) + lentitud horrible. Acá guardamos el resultado
// del primer geocoding y reusamos. El cron diario completa los huecos.
//
// La key es `ubicacion` (texto crudo del reporte) — si Varone reporta "Acceso
// Sudeste km 12" y "Acceso Sudeste KM 12", quedan como 2 rows distintas. Es
// trade-off consciente: normalizar agresivo perdería precisión semántica.
//
// `provider` permite mezclar fuentes en el futuro (Mapbox, Google) sin
// invalidar todo el cache.
//
// `notFound` marca ubicaciones que Nominatim no pudo resolver — así no
// re-intentamos cada hora. Si vale la pena, Varone las puede editar manual.
model UbicacionGeocoded {
  id          Int      @id @default(autoincrement())
  ubicacion   String   @unique
  // Coordenadas. Null si notFound=true.
  lat         Float?
  lng         Float?
  // Display name que retornó el geocoder (audit / debugging).
  displayName String?  @map("display_name")
  // 'nominatim' | 'mapbox' | 'manual' | ...
  provider    String   @default("nominatim")
  // Si el geocoder no resolvió, true. Evita re-intentos infinitos.
  notFound    Boolean  @default(false) @map("not_found")
  geocodedEn  DateTime @default(now()) @map("geocoded_en")

  @@map("ubicaciones_geocoded")
  @@index([notFound])
  @@index([provider])
}

// Sprint scrapers-portales (2026-06-30) — auditoría de descartes del pre-filtro.
//
// Cada nota que un scraper trae pasa por `prefiltro.ts`. Si la nota:
//  - matchea blacklist (narco / droga / etc.) → razon='blacklist'
//  - no matchea ninguna whitelist             → razon='sin-keywords'
//  - matchea whitelist sin blacklist          → pasa al pipeline IA
//
// Esta tabla guarda los DESCARTES con TTL 14 días (cron limpieza). Sirve para:
//  1. Auditar las keywords del pre-filtro ("¿estoy tirando algo que sí era?")
//  2. Tunear whitelist/blacklist con data real las primeras semanas
//  3. Ver desde el admin /descartados los últimos N
//
// NO guardamos descartes de la IA (`esRelevante: false`) — ese es otro mecanismo
// upstream del pipeline existente que no toca esta tabla.
model ScrapeDescartado {
  id            Int      @id @default(autoincrement())
  portal        String   // 'clarin' | 'cronica' | etc.
  url           String?  // URL de la nota original
  titulo        String   // titular
  resumen       String?  // primer párrafo si lo extrajimos
  razon         String   // 'blacklist' | 'sin-keywords'
  matchedKeywords String[] @map("matched_keywords") @default([])
  descartadoEn  DateTime @default(now()) @map("descartado_en")

  @@map("scrapes_descartados")
  @@index([portal])
  @@index([razon])
  @@index([descartadoEn])
  @@unique([portal, url])  // evita duplicar el mismo descarte si el scraper corre 2 veces
}

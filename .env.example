# Base de datos PostgreSQL
DATABASE_URL=postgresql://varone:varone_secret@localhost:5432/sistema_varone

# IA — elegir uno
AI_PROVIDER=gemini                        # 'gemini' | 'openai'
GEMINI_API_KEY=tu_api_key_de_google
OPENAI_API_KEY=                           # solo si AI_PROVIDER=openai

# WhatsApp — nombre EXACTO del grupo (sensible a mayúsculas y espacios)
WA_GROUP_NAME=Mesa Pirateria Camiones

# Framer — microservicio publisher (Server API oficial)
FRAMER_PUBLISHER_URL=http://127.0.0.1:4001
FRAMER_PUBLISHER_TOKEN=                   # mismo valor que en framer-publisher/.env

# Token compartido para bypass de auth desde varone-admin (Next.js).
# Generar uno largo y único: `openssl rand -hex 32`
BACKEND_API_TOKEN=

# Secret para firmar tokens de "quick action" (links Aprobar/Descartar
# que Varone recibe por WhatsApp). HMAC-SHA256, mínimo 32 chars.
# Generar: `openssl rand -hex 32`
QUICK_ACTION_SECRET=

# URL pública del panel admin para armar los links en las notificaciones.
# En dev: http://localhost:3001 — en prod: https://admin.tudominio.com
ADMIN_PUBLIC_URL=http://localhost:3001

# Backups de la DB (cron diario a las 3am AR).
# Por default: backups/ relativo al cwd, retención 30 días.
BACKUP_DIR=backups
BACKUP_RETAIN_DAYS=30

# Webhook de salida legacy (no se usa con la integración nueva)
FRAMER_ENDPOINT=

# Scraping
SCRAPING_INTERVAL_MINUTES=120             # frecuencia en minutos (default: 120)

# Dashboard web
DASHBOARD_USER=varone
DASHBOARD_PASS=cambia_esta_clave          # OBLIGATORIO cambiar en producción

# Número de WhatsApp para alertas operacionales (formato internacional sin + ni espacios)
# Requerido en producción — es el número que recibe alertas de desconexión y spikes
VARONE_WA_NUMBER=5491144462389            # ejemplo: 54 (Argentina) + 9 + código área + número

# Alertas Telegram (opcional — si no se configura, solo logea en consola)
TELEGRAM_BOT_TOKEN=                       # token del bot de Telegram
TELEGRAM_CHAT_ID=                         # chat_id donde enviar alertas

# Entorno
NODE_ENV=development                      # 'development' | 'production'
LOG_LEVEL=info                            # 'debug' | 'info'

# Base de datos
DATABASE_URL=postgresql://varone:varone_secret@localhost:5432/sistema_varone

# IA - elegir "gemini" o "openai"
AI_PROVIDER=gemini
GEMINI_API_KEY=tu_api_key_aqui
OPENAI_API_KEY=

# WhatsApp - nombre exacto del grupo a monitorear
WA_GROUP_NAME=Nombre del Grupo

# Framer - endpoint del formulario
FRAMER_ENDPOINT=https://tu-proyecto.framer.website/api/form

# Scraping - intervalo en minutos
SCRAPING_INTERVAL_MINUTES=120

# General
NODE_ENV=development
LOG_LEVEL=info
